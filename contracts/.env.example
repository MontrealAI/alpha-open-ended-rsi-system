# RPC endpoints
MAINNET_RPC_URL=
MAINNET_RPC_URL_SECONDARY=
MAINNET_FORK_RPC_URL=
SEPOLIA_RPC_URL=

# Private key used by the deployer account (no 0x prefix also accepted)
DEPLOYER_PRIVATE_KEY=

# Role targets (required for deployment + handoff)
ADMIN_OWNER_ADDRESS=
PAUSER_ADDRESS=
EMERGENCY_GUARDIAN_ADDRESS=
TREASURY_ADDRESS=
REVIEWER_REWARD_TREASURY_ADDRESS=
COUNCIL_ADMIN_ADDRESS=

# External dependency addresses (optional legacy fallback; deployment-config JSON is authoritative)
AGI_TOKEN_ADDRESS=
AGIJOBMANAGER_ADDRESS=
DEPLOYMENT_CONFIG_PATH=

# Optional verification and ENS settings
ETHERSCAN_API_KEY=
ENS_REGISTRY_ADDRESS=
NAMEWRAPPER_ADDRESS=
PUBLIC_RESOLVER_ADDRESS=
ENS_NAME=

# Optional ownership transfer source addresses (used only when manifest path is unavailable)
ALPHA_NOVA_SEED_ADDRESS=
SIGNED_ATTESTATION_VERIFIER_ADDRESS=
THRESHOLD_NETWORK_ADAPTER_ADDRESS=
REVIEWER_REWARD_TREASURY_ADDRESS=
COUNCIL_GOVERNANCE_ADDRESS=
CHALLENGE_POLICY_MODULE_ADDRESS=
NOVA_SEED_REGISTRY_ADDRESS=
NOVA_SEED_WORKFLOW_ADAPTER_ADDRESS=

# Explicit safety gates
ALLOW_DEPLOY_TO_SEPOLIA=false
ALLOW_DEPLOY_TO_MAINNET=false
ALLOW_OWNERSHIP_TRANSFER=false
ALLOW_ENS_PUBLISH=false
